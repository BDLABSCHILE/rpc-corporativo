# ── Catálogo ────────────────────────────────────────────────────────────────
# true = catálogo demo (mock). false = Shopify real del cliente.
USE_MOCK_PRODUCTS=true
SHOPIFY_STORE_DOMAIN=
SHOPIFY_STOREFRONT_API_TOKEN=
SHOPIFY_ADMIN_CLIENT_ID=
SHOPIFY_ADMIN_CLIENT_SECRET=

# ── Cotizaciones por correo (Resend) ────────────────────────────────────────
# Sin key: modo prueba (loggea, no envía). Se activa al crear la cuenta Resend
# del cliente y verificar el dominio ropapublicitariachile.cl.
RESEND_API_KEY=
RESEND_FROM_EMAIL=cotizaciones@ropapublicitariachile.cl
RESEND_INTERNAL_EMAIL=hola@ropapublicitariachile.cl

# ── Sitio ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://ropapublicitariachile.cl
